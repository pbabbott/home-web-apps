PORT=4003

# Absolute path video-worker resolves job input/output paths against.
# Job inputPath/outputPaths are always relative to, and constrained within,
# this directory. Should point at the same media root as video-api.
MEDIA_ROOT=/change/me/to/a/local/media/directory

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DATABASE=video_api
POSTGRES_USER=video_api
POSTGRES_PASSWORD=Password123

# How often (ms) an idle worker polls for a pending job.
POLL_INTERVAL_MS=5000

# Path/binary name used to invoke ffmpeg. Must be on PATH in the container.
FFMPEG_PATH=ffmpeg
