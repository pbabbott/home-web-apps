{
  "name": "@abbottland/fui-components",
  "private": true,
  "version": "0.4.5",
  "type": "module",
  "scripts": {
    "docker:build": "abctl docker build",
    "docker:publish": "abctl docker publish",
    "build": "pnpm run build:storybook",
    "serve": "pnpm dlx serve storybook-static --listen 6006 --single",
    "build:npm": "NODE_ENV=production tsc -b && NODE_ENV=production vite build",
    "build:npm:clean": "rm -rf dist",
    "build:storybook": "NODE_OPTIONS='--max-old-space-size=2048' storybook build",
    "lint": "eslint .",
    "dev": "storybook dev -p 6006 --no-open",
    "clean": "rm -rf dist storybook-static",
    "test:ui": "pnpm run test:playwright && pnpm run test:dom",
    "test:dom": "vitest run",
    "test:watch": "vitest watch",
    "test:playwright": "playwright test",
    "test:playwright:generate": "tsx scripts/generate-story-tests.ts",
    "test:playwright:update-snapshots": "playwright test --update-snapshots",
    "test:playwright:report": "playwright show-report"
  },
  "main": "./dist/fui-components.umd.js",
  "module": "./dist/fui-components.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fui-components.es.js",
      "require": "./dist/fui-components.umd.js"
    },
    "./globals.css": "./globals.css",
    "./tailwind.config": "./tailwind.config.ts"
  },
  "peerDependencies": {
    "@xyflow/react": "^12.0.0",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "peerDependenciesMeta": {
    "@xyflow/react": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@tailwindcss/vite": "^4.1.16",
    "animejs": "^3.2.2",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@abbottland/abctl": "workspace:*",
    "@xyflow/react": "^12.0.0",
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "^10.0.0",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/addon-onboarding": "^10.0.0",
    "@storybook/addon-themes": "^10.0.2",
    "@storybook/addon-vitest": "^10.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@types/animejs": "^3.1.13",
    "@types/node": "^24.6.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "@vitest/browser-playwright": "^4.0.4",
    "@vitest/coverage-v8": "^4.0.4",
    "ejs": "^3.1.10",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "eslint-plugin-storybook": "^10.0.0",
    "globals": "^16.4.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "^10.0.2",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.3",
    "vite-plugin-static-copy": "^3.1.4",
    "vitest": "^4.0.4"
  }
}
