{
  "description": "Typescript configuration for building the project",
  "extends": "@abbottland/typescript-config/ts-lib-build.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "Node16",
    "moduleResolution": "Node16"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.test.ts"],
  "ts-node": {
    "esm": true
  }
}
