{
  "name": "@abbottland/abctl",
  "description": "Abbottland control CLI for common repository tasks",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsc -w -p tsconfig.build.json",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts*\" --max-warnings 0",
    "clean": "shx rm -rf dist && shx rm -f oclif.manifest.json",
    "build:docs": "oclif manifest && oclif readme",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.ts --selectProjects unit"
  },
  "bin": {
    "abctl": "./bin/run.js"
  },
  "dependencies": {
    "@1password/op-js": "^0.1.13",
    "@abbottland/yaml-config": "workspace:*",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "execa": "^9.5.2",
    "@oclif/plugin-plugins": "^5"
  },
  "devDependencies": {
    "@abbottland/eslint-config": "workspace:*",
    "@abbottland/jest-presets": "workspace:*",
    "@abbottland/typescript-config": "workspace:*",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "jest": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:",
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "chai": "^4",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "oclif": "^4",
    "shx": "^0.3.3"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts"
}
