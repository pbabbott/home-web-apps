{
  "name": "home-web-apps",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:abctl": "turbo run build --filter=@abbottland/abctl",
    "docker:build": "turbo run docker:build",
    "docker:publish": "turbo run docker:publish",
    "env:generate": "turbo run env:generate",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "dev:ui": "turbo run dev --filter=@abbottland/blog --filter=@abbottland/fui-components --filter=@abbottland/diagram-maker",
    "dev:deps": "turbo run dev:deps",
    "dev:deps:down": "turbo run dev:deps:down",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "test:unit": "turbo run test:unit",
    "test:int": "turbo run test:int",
    "test:smoke": "turbo run test:smoke",
    "storybook": "turbo run storybook",
    "graph": "turbo graph",
    "smoke:deps": "turbo run smoke:deps",
    "smoke:deps:build": "turbo run smoke:deps:build",
    "smoke:deps:down": "turbo run smoke:deps:down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.11",
    "eslint": "^9.16.0",
    "husky": "^9.1.7",
    "jest-junit": "catalog:",
    "prettier": "^3.6.2",
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=7.0.0"
  },
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2"
  }
}
