{
  "name": "Node.js Development Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1.7.1": {
      "version": "22",
      "pnpmVersion": "10.15.0"
    },
    "ghcr.io/devcontainers/features/common-utils:2.5.7": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "upgradePackages": true
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2.16.1": {},
    "ghcr.io/itsmechlark/features/1password:1": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1.3.1": {
      "helm": "none",
      "minikube": "none"
    },
    "ghcr.io/rio/features/skaffold:2.0.0": {},
    "ghcr.io/devcontainers-contrib/features/kubectx-kubens:1.0.6": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "mounts": [
    "type=bind,source=/home/${localEnv:USER}/.ssh,target=/home/vscode/.ssh,readonly"
  ],
  "runArgs": ["--env-file", ".devcontainer/.env"],
  "customizations": {
    "vscode": {
      "extensions": [
        "yzhang.markdown-all-in-one",
        "aaron-bond.better-comments",
        "vscode-icons-team.vscode-icons",
        "streetsidesoftware.code-spell-checker",
        "bierner.markdown-mermaid",
        "mikestead.dotenv",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "github.copilot",
        "github.vscode-github-actions",
        "unifiedjs.vscode-mdx",
        "anthropic.claude-code"
      ],
      "settings": {
        "typescript.tsdk": "node_modules/typescript/lib",
        "debug.javascript.autoAttachFilter": "disabled"
      }
    }
  },
  "containerUser": "vscode",
  "postStartCommand": "/workspaces/home-web-apps/.devcontainer/init-script.sh"
}
